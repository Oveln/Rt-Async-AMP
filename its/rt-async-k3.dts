// SPDX-License-Identifier: MIT
//
// K3 RT24 rcpu1 设备树（内嵌进 rt-async ELF）
//
// U-Boot 对 RT24 **不做任何 DTB handoff**（k3-rproc.c 只 memcpy ELF 的
// PT_LOAD 段，不传 DTB 指针、不扫 FDT magic）。故本 DTB 经 `include_bytes!`
// 内嵌进 rcpu1 固件 ELF 的 .rodata 段，`Board::init` 直接 `init_dtb(...)`。
//
// 本 DTB 只描述 **rcpu1（hart 1）视角**：rcpu0（官方 esos）在另一 ELF 里，
// 两者由 U-Boot 从同一 itb 的 rcpu0-fw / rcpu1-fw 节点分别加载。
//
// 地址均为 rcpu1 物理视图（与 AP 共享同一物理地址空间，无别名）：
//   - SysTimer 0xe4000000：mtime(+0xbff8，全局)/mtimecmp(+0x4000+hart<<27)/
//     MSIP(+0x0+hart<<27，已上板实测)
//   - PLIC  0xe0000000：自定义布局，stride hart<<27
//   - UART0 0xc0881000：PXA 派生，IRQ 17（时钟链由 CCU driver 经 clocks
//     属性在 probe 前自动配置，pinmux 由 pinctrl-single driver 在 probe
//     前自动应用；SPL 握手见 handshake 模块）
//
// 编译链：cc -E（展开 #include/#define 宏）→ dtc（求值算术，生成 .dtb）。
// 宏定义见 k3-pinctrl.h（与 esos 互用）+ k3-clock.h（时钟 ID）。

/dts-v1/;

#include "k3-pinctrl.h"
#include "k3-clock.h"

/ {
	#address-cells = <2>;
	#size-cells = <2>;
	model = "ov,rt-async-k3";
	compatible = "ov,rt-async";

	// pinctrl-single 控制器（必须排在 serial 之前：DFS 先序保证
	// pinctrl driver 先 probe 并注册进 PINCTRL slot，之后 serial 节点
	// 在 probe 前自动应用 pinctrl-0 引脚配置）。
	pinctrl@d401e000 {
		compatible = "pinctrl-single";
		reg = <0x0 0xd401e000 0x0 0x250>;
	};

	// CCU 时钟控制器（DFS 先序：排在所有需时钟的外设之前，保证 CCU
	// driver 先 probe 注册进 CLOCK slot）。#clock-cells=<1> 表示 clocks
	// 属性里 phandle 后跟 1 个 ID cell（K3_CLK_xxx）。
		ccu: ccu@c0880000 {
			compatible = "spacemit,k3-ccu";
			reg = <0x0 0xc0880000 0x0 0x1000>;
			#clock-cells = <1>;
		};

		// 核间信令 mailbox（纯门铃模式，数据走共享内存 ov-rpc）。
		// rcpu-communicate 属性表示本节点由 rcpu1 视角使用（USER1=本地）。
		// 两实例方向：
		//   mailbox3（starryos -> rcpu1）：基址 0xCAC90C00，IRQ 68
		//   mailbox4（rcpu1 -> starryos）：基址 0xCAC91000，IRQ 69
		mailbox3: mailbox@cac90c00 {
			compatible = "spacemit,k3-mailbox";
			reg = <0x0 0xcac90c00 0x0 0x400>;
			interrupts = <68>;
			rcpu-communicate;
		};

		mailbox4: mailbox@cac91000 {
			compatible = "spacemit,k3-mailbox";
			reg = <0x0 0xcac91000 0x0 0x400>;
			interrupts = <69>;
			rcpu-communicate;
		};

	chosen {
		stdout-path = "/serial@c0881000";
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;
		// K3 SysTimer 频率 24MHz（esOS SOC_TIMER_FREQ）。
		// fdt_parser 用此推导 timebase；ClintK3 driver 也读它作 freq。
		timebase-frequency = <24000000>;

		cpu@1 {
			device_type = "cpu";
			// reg=<1> + 单 cpu 节点 → dtc 推导 boot_cpuid_phys=1，
			// driver probe 据此算 (mhartid<<27) per-hart 窗口。
			reg = <1>;
			compatible = "spacemit,rt24", "riscv";
		};
	};

	// R_UART0 引脚配置（原 clock.rs 硬编码的 ruart0_3_cfg：GPIO_122/123）。
	// K3_PADCONF 展开 → ((pinid)*4) (conf) 两组 cell，dtc 求值为
	// <0x1e8 0xd044 0x1ec 0xd044>（offset, value 对）。
	ruart0_3_cfg: ruart0-3-cfg {
		pinctrl-single,pins = <
			K3_PADCONF(GPIO_122, (MUX_MODE4 | EDGE_NONE | PULL_UP | PAD_DS8))  /* r_uart0_tx */
			K3_PADCONF(GPIO_123, (MUX_MODE4 | EDGE_NONE | PULL_UP | PAD_DS8))  /* r_uart0_rx */
		>;
	};

	// R_UART0（PXA 派生）。时钟链（ruart_14 上游 gate + UART0 末端 gate）
	// 由 CCU driver 经 clocks 属性在 probe 前自动配置；pinmux 由
	// pinctrl-single driver 在 probe 前据 pinctrl-0 自动应用。
	serial@c0881000 {
		compatible = "spacemit,pxa-uart0";
		reg = <0x0 0xc0881000 0x0 0x100>;
		pinctrl-names = "default";
		pinctrl-0 = <&ruart0_3_cfg>;
		clocks = <&ccu K3_CLK_RUART0>;
	};

	// SysTimer（mtime/mtimecmp）。compatible 用 K3 专属串，回退 riscv,clint0。
	systimer@e4000000 {
		compatible = "spacemit,k3-systimer", "riscv,clint0";
		reg = <0x0 0xe4000000 0x0 0x10000>;
	};

	// SysTimer MSIP（与 systimer 同 reg，单独节点以便 Ipi driver 独立 probe）。
	msip@e4000000 {
		compatible = "spacemit,k3-systimer-msip", "riscv,clint0-msip";
		reg = <0x0 0xe4000000 0x0 0x10000>;
	};

	// K3 PLIC（自定义布局，stride hart<<27，compatible 仍为 riscv,plic0）。
	intc@e0000000 {
		compatible = "riscv,plic0";
		reg = <0x0 0xe0000000 0x0 0x4000000>;
	};
};
