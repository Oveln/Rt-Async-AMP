# rt-async-amp 共享约定配置
#
# 本文件定义两个系统 (rt-async / StarryOS) 之间的地址约定。
# 所有涉及跨系统通信的代码都应引用此文件中的值。
#
# 格式: KEY=VALUE (shell/Makefile 兼容, 不加引号)
# 地址前缀 0x

# ── 物理内存布局 ───────────────────────────────────────────────────────────
# QEMU virt 256M RAM: 0x80000000 ~ 0x90000000

# OpenSBI 固件加载地址 (fw_dynamic.bin)
OPENSBIBASE=0x80000000
OPENSBISIZE=0x80000

# StarryOS 加载地址 (通过 -kernel)
STARRYOSBASE=0x80200000

# rt-async 加载地址 (通过 -device loader)
RTASYNCBASE=0x82800000
RTASYNCSIZE=0x800000

# ── IPC 共享内存 ───────────────────────────────────────────────────────────
# ov_channal SharedMemory: 2 × 131 × 256 = 67072 bytes
# Channel 0: StarryOS → rt-async
# Channel 1: rt-async → StarryOS

SHMBASE=0x88000000
SHMSIZE=67072

# ── 中断约定 ───────────────────────────────────────────────────────────────
# rt-async (hart 1, M-mode): 通过 CLINT MSIP0 (0x2000000) 通知 StarryOS
# StarryOS (hart 0, S-mode): 通过 SBI ecall (IPI ext) 通知 rt-async

# CLINT MSIP 寄存器 (hart 0: +0x0, hart 1: +0x4)
CLINTBASE=0x2000000

# ── 外设 ────────────────────────────────────────────────────────────────────
# UART0: OpenSBI / StarryOS
# UART1: rt-async (自定义 QEMU)
UART0BASE=0x10000000
UART1BASE=0x10002000

# ── ioctl 命令号 (rt_shm 设备) ──────────────────────────────────────────────
RTSHM_IOC_NOTIFY=0x735001
RTSHM_IOC_AWAIT=0x735002

# ── SBI 常量 ───────────────────────────────────────────────────────────────
SBI_EXT_IPI=0x735049
SBI_FUNC_SEND_IPI=0x00

# ── QEMU 配置 ──────────────────────────────────────────────────────────────
QEMUSMP=2
QEMURAM=256M
